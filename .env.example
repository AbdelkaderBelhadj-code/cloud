# ─── Backend ──────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://localhost:27017/license_mgmt

# JWT
JWT_SECRET=change_this_to_a_very_long_random_secret_key_at_least_64_chars
JWT_EXPIRES_IN=8h

# Email — Option 1: Gmail (free, 500 emails/day)
# Requires: Gmail 2-Step Verification + App Password
SMTP_SERVICE=gmail
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-16-char-app-password
SMTP_SECURE=false
MAIL_FROM=your-gmail@gmail.com
NOTIFICATION_EMAIL=cloud@nextstep-it.com

# Email — Option 2: Postfix / custom SMTP (remove SMTP_SERVICE to use this)
# SMTP_HOST=localhost
# SMTP_PORT=25
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM=noreply@nextstep-it.com

# Frontend CORS origin
CLIENT_URL=http://localhost:5173
